# App config (KEY=VALUE format; python-dotenv parses this).
# Most configuration is now edited in the browser at /admin and persisted to
# app/data/app_config.yaml. These env vars are optional overrides.
NL2DB_APP_NAME=NL2DB
NL2DB_CONFIG_PATH=app/data/app_config.yaml
# NL2DB_LLM_API_KEY / model etc. are set in the admin UI or here as overrides.
